{
  "name": "@inkbeard/ui-vue",
  "type": "module",
  "version": "0.16.0",
  "main": "./index.ts",
  "files": [
    "assets"
  ],
  "exports": {
    ".": "./index.ts",
    "./changelog.md": "./CHANGELOG.md",
    "./readme.md": "./README.md",
    "./*.css": {
      "import": "./src/assets/*.css"
    }
  },
  "scripts": {
    "build": "vite build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --cache",
    "lint:fix": "pnpm lint --fix",
    "stylelint": "stylelint \"**/*.{css,scss,vue}\""
  },
  "dependencies": {
    "primevue": "^3.53.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@inkbeard/eslint-config": "workspace:*",
    "@inkbeard/stylelint-config": "workspace:*",
    "@inkbeard/ui-theme": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-istanbul": "4.1.5",
    "@vitest/ui": "4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^8.57.1",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}